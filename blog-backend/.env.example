# Express API Port configuration
PORT=3000
NODE_ENV=production

# Admin account credentials
# Update this with your desired administrator email
ADMIN_EMAIL=admin@shivangcodes.in

# Hashed password (Bcrypt)
# If you run the server and attempt to log in, it will print a warning 
# in the console showing the correct hash format for whatever password you entered.
# You can then copy and paste that generated hash here.
ADMIN_PASSWORD_HASH=$2a$10$3zP2Kq.bEqgDq0r0sDkEq.3F2g5z8H8uV.YhP34T6U2FhF6zVq2sW

# JWT security key
# Use a long, random alphanumeric string. Generate one using: openssl rand -base64 32
JWT_SECRET=super_secret_jwt_sign_key_change_me_in_production
